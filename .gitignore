# Datasets (downloaded separately, see README section 4)
dataset/

# VQ-VAE / evaluator checkpoints (see prepare/download_vqvae.sh, download_evaluators.sh)
checkpoints/

# GloVe word vectors (see prepare/download_glove.sh)
glove/

# Generated visualizations (eval_*_visualize.py --out_dir)
visualizations/

# Pretrained / fine-tuned model checkpoints, downloaded from HuggingFace or produced by
